{
  "manifest_version": 3,
  "name": "截图数字求和",
  "version": "1.3",
  "description": "粘贴或上传一张数字截图，自动识别并求和",
  "action": {},
  "permissions": [
    "sidePanel",
    "clipboardWrite"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  }
}
